# Virtual environments
venv/
.venv/

# Python cache
__pycache__/
*.pyc

# Local database files (do not commit; each developer keeps their own)
*.db
instance/

# Local environment variables (secrets)
.env

# User-uploaded post images (directory kept via .gitkeep)
static/uploads/posts/*
!static/uploads/posts/.gitkeep

# macOS system files
.DS_Store
